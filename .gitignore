# --- [Python/Venv] ---
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.env
.env.*


# Ignore IDE or editor configuration files.
build/
dist/
.vscode/
.idea/

# Ignore files.
*.log
*.spec
*.csv
*.xlsx
*.jsonl
*Zone.Identifier


# 세팅 폴더 제거 
/settings/

# --- [Logs & Artifacts] (가장 중요) ---
# 데모를 돌리면서 생성된 로컬 로그와 트레이스 파일들은 절대 올리지 않음
*.jsonl
showcase_history.jsonl
demo_traces.jsonl
scripts/demo_traces.jsonl

# --- [System] ---
.DS_Store
Thumbs.db

# --- [Exceptions] ---
# settings 폴더 안에 있는 설정용 JSON은 코드의 일부이므로 예외적으로 허용
!settings/*.json